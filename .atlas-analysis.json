  "keyFeatures": [
    "Probabilistic membership queries with confidence levels",
    "Witness-based distributed reporting system",
    "Network partition detection and refusal semantics",
    "Irreversible death finality with high confidence thresholds",
    "Trust scoring and Byzantine fault tolerance",
    "HTTP API and CLI for easy integration",
    "Formal verification with TLA+ specification"
  ],
  "publicApiSurface": [
    "GET /query?target={id} - Query node liveness status",
    "POST /report - Submit witness belief report",
    "POST /witnesses - Register a witness",
    "GET /health - Health check endpoint",
    "styx query <node_id> - CLI query command",
    "styx report <witness> <target> <alive> <dead> <unknown> - CLI report command",
    "styx health - CLI health check command",
    "Oracle.Query(target) - Go SDK query method",
    "Oracle.ReceiveReport(witness, target, belief) - Go SDK report method",
    "types.Belief - Probability distribution type",
    "types.NodeID - Node identifier type"
  ]
